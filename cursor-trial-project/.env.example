# Copy this file to `.env` in the project root and replace the placeholder with your real key.
# Do not put real secrets in this file — it is meant to be committed as a template.
# Restart `npm run dev` after changing env vars.

VITE_OPENWEATHER_API_KEY=YOUR_OPENWEATHERMAP_API_KEY_HERE

# Optional: default city shown on first load (OpenWeatherMap "q" parameter).
VITE_WEATHER_DEFAULT_CITY=New York

# Google OAuth Web Client ID (for sign-in + Calendar/Tasks access tokens)
VITE_GOOGLE_CLIENT_ID=YOUR_GOOGLE_WEB_CLIENT_ID_HERE

# Optional: override requested scopes
VITE_GOOGLE_AUTH_SCOPE=openid profile email https://www.googleapis.com/auth/calendar.readonly https://www.googleapis.com/auth/tasks
